{
  "name": "kenchiku-boost",
  "version": "2.9.6",
  "description": "建築ブースト — AI建築見積・請求書管理デスクトップアプリ",
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "start": "npm run build && electron .",
    "dev": "webpack --config webpack.config.js --watch",
    "dist": "npm run build && electron-builder --win portable"
  },
  "keywords": [
    "建築",
    "見積",
    "請求書"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "localtunnel": "^2.0.2",
    "nodemailer": "^8.0.10",
    "openai": "^6.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sql.js": "^1.14.1"
  },
  "build": {
    "appId": "com.kenchiku.boost",
    "productName": "建築ブースト",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!src/**/*",
      "!*.ts",
      "!*.tsx",
      "!webpack.config.js",
      "!tsconfig.json",
      "!seed-*.js",
      "!launch.vbs",
      "!package-lock.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "kenchiku-boost-v${version}-setup.exe",
      "shortcutName": "建築ブースト"
    }
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "html-webpack-plugin": "^5.6.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  }
}
